{
	"$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": ["**", "!**/.astro", "!**/*.astro", "!**/test/fixtures"]
	},
	"formatter": {
		"enabled": false
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"complexity": {
				"useLiteralKeys": "off"
			},
			"style": {
				"useImportType": "error"
			},
			"correctness": {
				"noUnusedVariables": "error"
			}
		}
	}
}
