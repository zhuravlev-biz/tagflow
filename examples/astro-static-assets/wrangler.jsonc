{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "example-astro-affiliate-links",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "analytics_engine_datasets": [
    {
      "binding": "CLICKS",
      "dataset": "affiliate_clicks"
    }
  ]
}
