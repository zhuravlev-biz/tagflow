{
  "name": "@tagflow/cloudflare",
  "version": "0.2.1",
  "description": "Cloudflare Worker adapter for localized Amazon affiliate links: mountable handler, 302 semantics, optional Analytics Engine click logging.",
  "license": "MIT",
  "author": "Alex Zhuravlev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhuravlev-biz/tagflow.git",
    "directory": "packages/cloudflare"
  },
  "homepage": "https://github.com/zhuravlev-biz/tagflow#readme",
  "bugs": {
    "url": "https://github.com/zhuravlev-biz/tagflow/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@tagflow/core": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "@cloudflare/workers-types": "5.20260719.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "keywords": [
    "amazon-associates",
    "affiliate",
    "onelink-alternative",
    "geniuslink-alternative",
    "cloudflare-workers"
  ]
}
