{
  "name": "@tagflow/core",
  "version": "0.2.0",
  "description": "Pure resolution engine for localized Amazon affiliate links: config schema, country-to-marketplace map, deterministic fallback resolution.",
  "license": "MIT",
  "author": "Alex Zhuravlev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhuravlev-biz/tagflow.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/zhuravlev-biz/tagflow#readme",
  "bugs": {
    "url": "https://github.com/zhuravlev-biz/tagflow/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage"
  },
  "keywords": [
    "amazon-associates",
    "affiliate",
    "onelink-alternative",
    "geniuslink-alternative",
    "cloudflare-workers"
  ],
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.10",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
